# ai-harness configuration. Copy this file to ".env" and fill in your values.
# The .env file is gitignored and is the ONLY place secrets live. Never commit real keys.

# Which backend to use: openai | azure | anthropic | local
AIHARNESS_PROVIDER=openai

# Model / deployment id for the chosen provider (for example: gpt-4o-mini).
AIHARNESS_MODEL=gpt-4o-mini

# --- openai ---
OPENAI_API_KEY=

# --- local (any OpenAI-compatible server, for example Ollama or vLLM) ---
# Base URL of the OpenAI-compatible endpoint, including the /v1 suffix.
LOCAL_BASE_URL=http://localhost:11434/v1
# Most local servers ignore the key; a placeholder is fine.
LOCAL_API_KEY=local

# --- azure (planned; wired in a later milestone) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- anthropic (planned; wired in a later milestone) ---
ANTHROPIC_API_KEY=
